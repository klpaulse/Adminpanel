{
  "name": "studiocore",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n STUDIOCORE,API -c cyan,green \"npm --prefix apps/studiocore run dev\" \"cd apps/api && mvn spring-boot:run\"",
    "dev:studiocore": "npm --prefix apps/studiocore run dev",
    "dev:api": "cd apps/api && mvn spring-boot:run",
    "dev:site": "npm --prefix sites/snekkerfirma run dev -- --port 5174"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}